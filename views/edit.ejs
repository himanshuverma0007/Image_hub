<% include ./partials/header.ejs %>

<div class="w-full min-h-screen bg-zinc-900 px-4 md:px-10 py-8 text-white">
  <div class="max-w-xl mx-auto">
    <h1 class="text-2xl font-bold mb-2">Edit Post</h1>
    <hr class="border-zinc-700 mb-6">

    <!-- Update Form -->
    <form action="/items/<%= item.id %>?_method=PUT" method="POST" class="flex flex-col gap-4">
      <input 
        class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg focus:outline-none focus:border-red-500 text-white placeholder-zinc-500" 
        type="text" 
        id="title" 
        name="title" 
        value="<%= item.title %>" 
        required
        placeholder="Title">
      <input 
        class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg cursor-pointer transition" 
        type="submit" 
        value="Update Post">
    </form>

    <!-- Delete Form -->
    <form action="/items/<%= item.id %>?_method=DELETE" method="POST" 
      onsubmit="return confirm('Are you sure you want to delete this item?');"
      class="mt-4">
      <button class="w-full py-3 bg-zinc-700 hover:bg-zinc-600 text-red-400 font-semibold rounded-lg transition" 
        type="submit">
        🗑️ Delete Post
      </button>
    </form>

    <a href="/profile" class="block text-center mt-4 text-zinc-400 hover:text-white transition">
      ← Back to Profile
    </a>
  </div>
</div>

<% include ./partials/footer.ejs %>