<% include ./partials/header.ejs %>

<div class="w-full min-h-screen bg-zinc-900 px-4 md:px-10 py-8 text-white">
  <div class="max-w-xl mx-auto">
    <h1 class="text-2xl font-bold mb-2">Edit Profile</h1>
    <hr class="border-zinc-700 mb-6">

    <!-- Profile Picture Upload -->
    <form action="/fileupload" method="post" enctype="multipart/form-data" class="flex flex-col gap-4">
      
      <div class="border-2 border-dashed border-zinc-600 rounded-xl p-6 text-center hover:border-red-500 transition">
        <i class="ri-image-line text-4xl text-zinc-400 mb-2"></i>
        <p class="text-zinc-400 text-sm mb-3">Upload New Profile Picture</p>
        <input class="w-full text-sm text-zinc-300" type="file" name="image" accept="image/*" required>
      </div>

      <input class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg cursor-pointer transition" 
        type="submit" value="Update Profile Picture">
    </form>

    <a href="/profile" class="block text-center mt-4 text-zinc-400 hover:text-white transition">
      ← Back to Profile
    </a>
  </div>
</div>

<% include ./partials/footer.ejs %>