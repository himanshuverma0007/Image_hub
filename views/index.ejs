<% include ./partials/header.ejs %>

<div class="w-full min-h-screen bg-cover bg-center flex items-center justify-center"
  style="background-image: url('https://images.unsplash.com/photo-1510936111840-65e151ad71bb?q=80&w=1790&auto=format&fit=crop')">
  
  <div class="w-full max-w-md mx-4 bg-white text-zinc-800 px-8 py-10 rounded-3xl shadow-2xl">
    <h1 class="text-3xl font-bold text-center text-zinc-700 mb-6">Welcome to ImageHub</h1>

    <form action="/login" method="post" class="flex flex-col gap-3">
      <input class="border-2 border-zinc-300 rounded-lg px-4 py-3 focus:outline-none focus:border-red-400 w-full" 
        type="text" name="username" placeholder="Username">
      <input class="border-2 border-zinc-300 rounded-lg px-4 py-3 focus:outline-none focus:border-red-400 w-full" 
        type="password" name="password" placeholder="Password">
      <a href="#" class="text-sm font-semibold text-zinc-500 hover:text-red-500">Forgot password?</a>
      <input class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-full cursor-pointer transition" 
        type="submit" value="Login">
      <p class="text-xs text-zinc-400 text-center">By continuing, you agree to ImageHub's Terms of Service and Privacy Policy.</p>
    </form>
    <a class="block text-sm font-semibold text-center mt-3 text-red-500 hover:underline" href="/register">
      Don't have an account? Sign Up
    </a>
  </div>
</div>

<% include ./partials/footer.ejs %>