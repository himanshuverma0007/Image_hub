<% include ./partials/header.ejs %>

<div class="w-full min-h-screen bg-zinc-900 px-4 md:px-10 py-8 text-white">
  <div class="max-w-xl mx-auto">
    <h1 class="text-2xl font-bold mb-2">Create New Post</h1>
    <hr class="border-zinc-700 mb-6">

    <form action="/createpost" method="post" enctype="multipart/form-data" class="flex flex-col gap-4">
      
      <!-- Image Upload -->
      <div class="border-2 border-dashed border-zinc-600 rounded-xl p-6 text-center hover:border-red-500 transition cursor-pointer">
        <i class="ri-upload-cloud-line text-4xl text-zinc-400 mb-2"></i>
        <p class="text-zinc-400 text-sm mb-3">Click to upload image</p>
        <input class="w-full text-sm text-zinc-300" type="file" name="postImage" accept="image/*" required>
      </div>

      <!-- Title -->
      <input class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg focus:outline-none focus:border-red-500 text-white placeholder-zinc-500" 
        type="text" name="title" placeholder="Post Title" required>

      <!-- Description -->
      <textarea class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg focus:outline-none focus:border-red-500 text-white placeholder-zinc-500 h-40 resize-none" 
        name="description" placeholder="Write a description..."></textarea>

      <!-- Submit -->
      <input class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg cursor-pointer transition" 
        type="submit" value="Create Post">
    </form>
  </div>
</div>

<% include ./partials/footer.ejs %>